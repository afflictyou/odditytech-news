# Never commit credentials or sensitive files
.env
.env.*
*.key
*.pem
config.local.php

# Logs and temp files
error_log
*.log
tmp/
*.swp

# OS junk
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/

# Server artifacts
.ftpquota

# Composer
# vendor/ is generated by `composer install` in CI before FTPS deploy,
# so we never commit it but it IS shipped to the live server.
/vendor/
composer.phar
